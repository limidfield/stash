name: Stash Rule Providersdesc: 仅加入 Local-IP、China-Site、China-IP 三个远程规则集category: ruleseticon: https://cdn.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Direct.pngrule-providers:  Local-IP:    type: http    behavior: ipcidr    format: mrs    url: https://cdn.jsdmirror.com/gh/HosheaPDNX/rule-set@V2.0.0/mihomo/Local/Local-IP.mrs    path: ./ruleset/Local-IP.mrs    proxy: DIRECT    interval: 86400  China-Site:    type: http    behavior: domain    format: mrs    url: https://cdn.jsdmirror.com/gh/HosheaPDNX/rule-set@V2.0.0/mihomo/China/China-Site.mrs    path: ./ruleset/China-Site.mrs    proxy: DIRECT    interval: 86400  China-IP:    type: http    behavior: ipcidr    format: mrs    url: https://cdn.jsdmirror.com/gh/HosheaPDNX/rule-set@V2.0.0/mihomo/China/China-IP.mrs    path: ./ruleset/China-IP.mrs    proxy: DIRECT    interval: 86400